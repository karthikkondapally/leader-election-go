# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# ── Database connection (choose ONE style) ────────────────────────────────────

# Style 1: Full DSN
PGELECT_DSN=postgres://postgres:postgres@localhost:5432/mydb?sslmode=disable

# Style 2: Explicit fields (comment out PGELECT_DSN above to use these)
# PGELECT_DB_HOST=localhost
# PGELECT_DB_PORT=5432
# PGELECT_DB_NAME=mydb
# PGELECT_DB_USER=postgres
# PGELECT_DB_PASSWORD=postgres
# PGELECT_DB_SSLMODE=disable

# ── Election identity ─────────────────────────────────────────────────────────
PGELECT_APP_NAME=my-worker
PGELECT_INSTANCE_ID=local-dev-1   # override with POD_NAME in Kubernetes

# ── Timing (optional — defaults are production-safe) ─────────────────────────
# PGELECT_LEASE_DURATION=15s
# PGELECT_RENEW_INTERVAL=5s
# PGELECT_RETRY_INTERVAL=5s
# PGELECT_RECONNECT_BACKOFF=3s
# PGELECT_SHUTDOWN_TIMEOUT=10s
# PGELECT_DRAIN_TIMEOUT=10s

# ── Schema ────────────────────────────────────────────────────────────────────
# PGELECT_AUTO_CREATE_SCHEMA=true   # handy for local dev; use migrations in prod
# PGELECT_TABLE_NAME=leader_leases  # override if you have a naming convention
